    "import numpy as np\n",
    "import pandas as pd\n",
    "\n",
    "numpy_array = np.array([4, 9, 16, 25, 36, 49, 64])\n",
    "series = pd.Series(numpy_array)\n",
    "\n",
    "filtered_series = series[series > 20]\n",
    "\n",
    "print(\"Исходный Series:\")\n",
    "print(series)\n",
    "\n",
    "print(\"\\nЭлементы больше 20:\")\n",
    "print(filtered_series)"
   ]
