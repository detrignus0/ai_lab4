    "import pandas as pd\n",
    "\n",
    "s = pd.Series([10, 20, 30, 40, 50, 60], index=[\"A\", \"B\", \"A\", \"C\", \"D\", \"B\"])\n",
    "print(s.index.is_unique)\n",
    "\n",
    "if not s.index.is_unique:\n",
    "    s = s.groupby(level=0).sum()\n",
    "    print(s)"
